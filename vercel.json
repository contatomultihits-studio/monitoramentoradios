{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/musical",
      "destination": "/musical.html"
    },
    {
      "source": "/comercial",
      "destination": "/comercial.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}