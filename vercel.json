{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/musical",
      "destination": "/musical.html"
    },
    {
      "source": "/comercial",
      "destination": "/comercial.html"
    },
    {
      "source": "/comercial-dashboard",
      "destination": "/comercial-dashboard.html"
    },
    {
      "source": "/comparacao",
      "destination": "/comparacao.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
